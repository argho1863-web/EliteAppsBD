# Environment Variables Template
# Copy this to .env.local and fill in the required values

# ─────────────────────────────────────────
# AI Product Importer Configuration
# ─────────────────────────────────────────

# OpenRouter API Key (Required)
# Get from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter Model (Optional - defaults to google/gemini-2.5-flash)
# Options:
#   - google/gemini-2.5-flash (recommended - fastest & cheapest)
#   - meta-llama/llama-3-70b-instruct (highest accuracy)
#   - mistralai/mistral-7b-instruct (budget-friendly)
OPENROUTER_MODEL=google/gemini-2.5-flash

# Web Scraping Timeout (Optional - milliseconds, default: 10000)
# SCRAPE_TIMEOUT=10000

# Maximum products to extract per import (Optional, default: unlimited)
# MAX_PRODUCTS=50

# ─────────────────────────────────────────
# Standard Database Configuration
# ─────────────────────────────────────────

# Database URL (Neon PostgreSQL)
# Already configured in your project
# DATABASE_URL=postgresql://...

# ─────────────────────────────────────────
# Authentication Configuration
# ─────────────────────────────────────────

# Admin credentials (for local testing)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password_here

# Google OAuth (if using social login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─────────────────────────────────────────
# Application URLs
# ─────────────────────────────────────────

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_secret_key_here

# ─────────────────────────────────────────
# File Upload Configuration
# ─────────────────────────────────────────

# Currently using local/API-based uploads
# Configure based on your storage solution
